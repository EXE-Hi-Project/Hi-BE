# ================================
# Hi API - Java Spring Boot
# ================================

# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hi_app
MONGODB_DB_NAME=hi_app

# JWT (must be at least 32 chars for HS256)
JWT_SECRET=your_jwt_secret_min_32_characters
JWT_EXPIRES_MS=604800000

# CORS
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=https://hilover.space,https://www.hilover.space
ALLOW_VERCEL_PREVIEW=false

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@example.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# PayOS Configuration
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
CLIENT_URL=http://localhost:5173

# Spring AI - Gemini (get from https://aistudio.google.com/app/apikey)
API_GEMINI=your_google_gemini_api_key
